# =============================================================================
# $CASTE Web Frontend — Environment Variables
# =============================================================================
# Copy to .env.local and fill in your values.
# All NEXT_PUBLIC_ vars are embedded at build time and visible to the browser.

# =============================================================================
# CHAIN
# =============================================================================

# Chain ID: 1 = Ethereum Mainnet, 11155111 = Sepolia
NEXT_PUBLIC_CHAIN_ID=11155111

# =============================================================================
# INDEXER
# =============================================================================

# URL of the running Ponder indexer (Hono HTTP server).
# Local dev default: http://localhost:42069
# Production: your deployed indexer URL
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069

# =============================================================================
# CONTRACT ADDRESSES
# =============================================================================
# Copy from DeploySepolia.s.sol console output or your deployment records.
# Must match the chain specified in NEXT_PUBLIC_CHAIN_ID.

NEXT_PUBLIC_CASTE_HOOK_ADDRESS=
NEXT_PUBLIC_CASTE_TOKEN_ADDRESS=
NEXT_PUBLIC_CASTE_CARD_ADDRESS=
NEXT_PUBLIC_MINT_MANAGER_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# =============================================================================
# WALLET CONNECT (optional — needed for WalletConnect modal)
# =============================================================================

# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
